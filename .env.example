# Copy to .env and change the secrets before any non-local use.
INTERNAL_SERVICE_TOKEN=dev-internal-token
JWT_ACCESS_SECRET=change-me-in-prod

# Optional — enables AI-written assessments. Works without it (templates).
ANTHROPIC_API_KEY=

# Optional SMTP for email alerts. Leave blank to log alerts to the console.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_FROM=blackout@localhost
