    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "2.4.3",
    "bullmq": "5.28.1",
    "cors": "2.8.5",
    "express": "4.21.1",
    "express-rate-limit": "7.4.1",
    "helmet": "8.0.0",
    "ioredis": "5.4.1",
    "jsonwebtoken": "9.0.2",
    "nodemailer": "6.9.16",
    "pdfkit": "0.15.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "22.9.0",
    "@types/nodemailer": "6.4.16",
    "@types/pdfkit": "0.13.5",
    "prisma": "5.22.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  }
